    # event-driven worker loop. ops/compose.fragment.yml emits both services.
    role = os.getenv("APP_ROLE", "worker")
    front.serve() if role == "api" else front.run()
{%- elif recipe == 'api' %}
    front.serve()   # synchronous request/response lifecycle
{%- else %}
    front.run()     # event-driven lifecycle
{%- endif %}


