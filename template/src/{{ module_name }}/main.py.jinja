logging.basicConfig(level=logging.INFO)


def build():
    director = FrontDirector({{ project_slug.replace('-', ' ').title().replace(' ', '') }}FrontBuilder())
    return director.build_{{ recipe }}_front()


def main() -> None:
    front = build()
{%- if recipe == 'gateway' %}
    # One image, two deployables: APP_ROLE selects the process this container runs.
